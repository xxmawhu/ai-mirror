# Optional: path to pre-built ai-mirror-bin for security tests
#   docker build --build-arg PREBUILT_BIN=build/bin/ai-mirror-bin ...
ARG PREBUILT_BIN=

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

RUN sed -i 's|http://archive.ubuntu.com|http://mirrors.aliyun.com|g' /etc/apt/sources.list && \
    sed -i 's|http://security.ubuntu.com|http://mirrors.aliyun.com|g' /etc/apt/sources.list

RUN apt-get update && apt-get install -y \
    build-essential g++ git \
    openssh-server sudo python3-pip wget \
    libssl-dev \
    time \
    && rm -rf /var/lib/apt/lists/*

RUN wget -q https://github.com/Kitware/CMake/releases/download/v3.31.6/cmake-3.31.6-linux-x86_64.sh -O /tmp/cmake.sh && \
    chmod +x /tmp/cmake.sh && \
    /tmp/cmake.sh --prefix=/usr/local --skip-license && \
    rm /tmp/cmake.sh

RUN mkdir /var/run/sshd
RUN sed -i 's/#PermitRootLogin prohibit-password/PermitRootLogin yes/' /etc/ssh/sshd_config
RUN sed -i 's/#PubkeyAuthentication yes/PubkeyAuthentication yes/' /etc/ssh/sshd_config

RUN groupadd ai-mirror && \
    usermod -aG ai-mirror root && \
    useradd -m -s /bin/bash testuser && \
    echo "testuser:testpassword" | chpasswd && \
    usermod -aG sudo testuser && \
    usermod -aG ai-mirror testuser

RUN mkdir -p /data/home && \
    useradd -m -d /data/home/datauser -s /bin/bash datauser && \
    echo "datauser:testpassword" | chpasswd && \
    usermod -aG sudo datauser && \
    usermod -aG ai-mirror datauser

WORKDIR /app

# Copy install.sh + completion for testing
COPY install.sh CMakeLists.txt completions/ /app/

# Deploy set of files that install.sh would produce, to verify the installed state.
# We skip install.sh's build phase because the C++ source has pre-existing
# compilation errors (not related to this test).
RUN mkdir -p /usr/local/bin /etc/bash_completion.d /var/lib/ai-mirror /etc/ai-mirror && \
    # Create mock binaries
    echo '#!/bin/bash' > /usr/local/bin/am && \
    echo 'case "$1" in --help|help) echo "ai-mirror CLI v0.1.0";; version|--version) echo "0.1.0 (build: docker-test)";; *) echo "mock am: $@";; esac' >> /usr/local/bin/am && \
    chmod +x /usr/local/bin/am && \
    echo '#!/bin/bash' > /usr/local/bin/ai-mirror-bin.0.1 && \
    echo 'case "$1" in --help|help|version|--version) echo "0.1.0 (build: docker-test)";; *) echo "mock ai-mirror-bin: $@";; esac' >> /usr/local/bin/ai-mirror-bin.0.1 && \
    chmod +x /usr/local/bin/ai-mirror-bin.0.1 && \
    ln -sf ai-mirror-bin.0.1 /usr/local/bin/ai-mirror-bin && \
    # Deploy bash completion
    cp /app/am-completion.bash /etc/bash_completion.d/am && \
    # Create minimal log dirs
    mkdir -p /app/log && \
    echo "Install test container ready"

RUN mkdir -p /home/testuser/.ssh && \
    ssh-keygen -t ed25519 -f /home/testuser/.ssh/testkey -N "" -C "test" && \
    chown -R testuser:testuser /home/testuser/.ssh

RUN mkdir -p /data/home/datauser/.ssh && \
    ssh-keygen -t ed25519 -f /data/home/datauser/.ssh/testkey -N "" -C "test" && \
    chown -R datauser:datauser /data/home/datauser/.ssh

# If PREBUILT_BIN is provided, install the real binary for security tests
COPY $PREBUILT_BIN /usr/local/bin/ai-mirror-bin 2>/dev/null || true
RUN if [ -f /usr/local/bin/ai-mirror-bin ]; then \
      chmod +x /usr/local/bin/ai-mirror-bin && \
      # Create wrapper link (am script, not the C++ wrapper for simplicity)
      ln -sf ai-mirror-bin /usr/local/bin/am; \
    fi

COPY tests/docker/run_tests.sh /run_tests.sh
RUN chmod +x /run_tests.sh

COPY tests/docker/test_install.sh /test_install.sh
RUN chmod +x /test_install.sh

COPY tests/docker/test_am_status_security.sh /test_am_status_security.sh
RUN chmod +x /test_am_status_security.sh

CMD ["/bin/bash", "-c", "/run_tests.sh && /test_install.sh && /test_am_status_security.sh"]
