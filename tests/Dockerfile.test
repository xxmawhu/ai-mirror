FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# Install build tools + runtime dependencies in single layer
RUN apt-get update && apt-get install -y --no-install-recommends \
    g++ cmake make git pkg-config libssl-dev ca-certificates \
    passwd \
    openssh-server openssh-client \
    mount util-linux \
    sudo \
    python3 \
    && rm -rf /var/lib/apt/lists/*

# Copy full source tree for in-container build
COPY . /opt/ai-mirror-src/

# Build from source
WORKDIR /opt/ai-mirror-src
RUN cmake -B build-test -DCMAKE_BUILD_TYPE=Debug . && \
    cmake --build build-test --target am ai-mirror-bin -j$(nproc)

# Install binaries
RUN install -d /usr/local/bin && \
    install -m 0755 build-test/bin/am /usr/local/bin/am && \
    install -m 0755 build-test/bin/ai-mirror-bin /usr/local/bin/ai-mirror-bin

# Setup runtime directories
RUN mkdir -p /etc/ai-mirror /var/lib/ai-mirror /root/.ssh /root/projects/testproj && \
    groupadd -f ai-mirror && \
    usermod -aG ai-mirror root

# Setup SSH host keys (required by test_ssh_login in run_tests.sh)
RUN mkdir -p /run/sshd && ssh-keygen -A

# Copy test scripts
COPY tests/run_tests.sh /tmp/run_tests.sh
RUN chmod +x /tmp/run_tests.sh

CMD ["/tmp/run_tests.sh"]
